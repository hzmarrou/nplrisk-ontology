# Entra service principal used to authenticate against the Fabric REST API.
# The app must have admin consent for Power BI Tenant.ReadWrite.All and
# must be added to the target Fabric workspace as Admin.
AZURE_TENANT_ID=<your-entra-tenant-id>
AZURE_CLIENT_ID=<your-service-principal-app-id>
AZURE_CLIENT_SECRET=<your-service-principal-client-secret>

# Target Fabric workspace that will own the ontology, graph model, tables,
# and data agents.
FABRIC_WORKSPACE_ID=<target-fabric-workspace-id>

# Target Lakehouse inside the workspace. Must already exist. This is the
# lakehouse that will hold the NPL domain tables and be referenced by both
# the ontology bindings and the data agents. Do NOT use the auto-created
# lakehouse that the ontology provisions for itself.
FABRIC_LAKEHOUSE_ID=<target-fabric-lakehouse-id>
